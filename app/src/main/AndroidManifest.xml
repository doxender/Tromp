<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location: foreground + background for pocket tracking -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service for continuous tracking with screen off -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Ongoing notification (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Step counter sensor (Android 10+ runtime permission) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Network: DEM lookups, online OSM tiles, tile pre-download -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- osmdroid writes tile cache to app-private storage; no external storage needed -->

    <uses-feature android:name="android.hardware.location.gps" android:required="true" />
    <uses-feature android:name="android.hardware.sensor.barometer" android:required="false" />

    <application
        android:name=".TrompApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Tromp"
        android:supportsRtl="true">

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.benchmark.BenchmarkActivity"
            android:exported="false"
            android:label="@string/benchmark_title"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.calibration.CalibrationActivity"
            android:exported="false"
            android:label="@string/calibration_title"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.summary.SummaryActivity"
            android:exported="false"
            android:label="@string/summary_title"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.map.MapActivity"
            android:exported="false"
            android:label="@string/map_title"
            android:parentActivityName=".ui.summary.SummaryActivity" />

        <activity
            android:name=".ui.history.HistoryActivity"
            android:exported="false"
            android:label="@string/history_title"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.benchmarks.BenchmarksActivity"
            android:exported="false"
            android:label="@string/benchmarks_title"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.licenses.LicensesActivity"
            android:exported="false"
            android:label="@string/licenses_title"
            android:parentActivityName=".ui.main.MainActivity" />

        <service
            android:name=".service.TrackingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location|dataSync" />

        <!-- Shares CSV exports via ACTION_SEND without leaking file:// URIs. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
